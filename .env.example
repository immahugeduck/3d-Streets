# Copy this file to .env.local and fill in your keys.
# Do NOT commit .env.local — it is already in .gitignore.

# ── Browser (Vite) ────────────────────────────────────────────────────────
# Mapbox public token — get one at https://account.mapbox.com/
VITE_MAPBOX_TOKEN=

# Google Maps / Places API key — get one at https://console.cloud.google.com/
# Required APIs: Places API (New), Maps JavaScript API
VITE_GOOGLE_MAPS_KEY=

# ── Server-only (Vercel Functions) ────────────────────────────────────────
# Anthropic API key — get one at https://console.anthropic.com/
# Set this in Vercel dashboard > Settings > Environment Variables.
# Do NOT use VITE_ prefix — it must never be bundled into the browser.
ANTHROPIC_API_KEY=

# Optional model override (default: claude-3-5-sonnet-latest)
ANTHROPIC_MODEL=

# Optional: comma-separated list of allowed CORS origins for the /api/ai endpoint.
# Leave blank to allow all origins (fine for public apps).
# Example: https://3dstreets.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=
